# ═══════════════════════════════════════════════════
# SecureFile Storage — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ───────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# ── JWT Secrets (min 32 chars, use: openssl rand -hex 32) ─
JWT_ACCESS_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-strong-random-secret-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Database (PostgreSQL) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securefile
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# ── Storage Provider ─────────────────────────────
# Options: 's3' | 'local'
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# S3 / MinIO (only needed when STORAGE_PROVIDER=s3)
#S3_BUCKET=securefile-bucket
#S3_REGION=us-east-1
#S3_ACCESS_KEY=your-access-key
#S3_SECRET_KEY=your-secret-key
#S3_ENDPOINT=http://localhost:9000   # MinIO endpoint (optional)

# ── File Upload Limits ────────────────────────────
MAX_FILE_SIZE_MB=100
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/zip,application/x-zip-compressed

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
UPLOAD_RATE_LIMIT_MAX=20

# ── Share / Temporary URLs ────────────────────────
SHARE_TOKEN_EXPIRES_IN_HOURS=24

# ── Security ──────────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000

# ── Virus Scanning (ClamAV) ───────────────────────
VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
